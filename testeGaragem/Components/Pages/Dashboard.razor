@page "/dashboard"
@layout EmptyLayout
@using testeGaragem.Models
@using testeGaragem.Services
@inject GaragemService GaragemService
@inject NavigationManager Navigation

    
<div class="app-wrapper">
    <header class="top-bar">
        <div class="brand-section">
            <div class="user-circle">👤</div>
            <span class="brand-text">GARAGEM 75</span>
        </div>
        <div class="notification-icon">🔔</div>
    </header>


    <main class="content-body">
        <h1 class="page-title">Indicadores</h1>

        <div class="stats-grid">
            <div class="stat-card main">
                <small>FATURAMENTO TOTAL</small>
                <h2>R$ @stats.TotalFaturado.ToString("N2")</h2>
            </div>
            <div class="stat-card">
                <small>TOTAL DE O.S.</small>
                <h2>@stats.QuantidadeOS</h2>
            </div>
        </div>

        <div class="progress-section">
            <h3>Status das Operações</h3>
            @foreach (var status in stats.StatusContagem)
            {
                <div class="progress-item">
                    <div class="progress-label">
                        <span><span class="dot @status.Cor"></span> @status.Nome</span>
                        <span class="progress-count">@status.Quantidade</span>
                    </div>
                    <div class="progress-bar-container">
                        @* Cálculo de porcentagem seguro *@
                        <div class="progress-bar @status.Cor" 
                             style="width: @(CalcularPorcentagem(status.Quantidade))%">
                        </div>
                    </div>
                </div>
            }
        </div>
    </main>

     <nav class="bottom-nav">
        <div class="nav-item active" @onclick='() => NavTo("dashboard")'><span>📊</span><span>Dashboard</span></div>
        <div class="nav-item" @onclick='() => NavTo("clientes")'><span>👥</span><span>Clientes</span></div>
        <div class="nav-item" @onclick='() => NavTo("veiculos")'><span>🚗</span><span>Veículos</span></div>
        <div class="nav-item" @onclick='() => NavTo("pecas")'><span>⚙️</span><span>Peças</span></div>
        <div class="nav-item" @onclick='() => NavTo("os")'><span>📋</span><span>OS</span></div>
    </nav>
</div>

<style>
    /* HEADER */
    .top-bar {
        background-color: #616161;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .brand-section { display: flex; align-items: center; gap: 10px; }
    .brand-text { color: #FFD700; font-weight: bold; font-size: 1rem; }
    .user-circle { background: #e0e0e0; width: 32px; height: 32px; border-radius: 50%; display: flex; justify-content: center; align-items: center; color: #333; }
    .notification-icon { color: white; cursor: pointer; display: flex; align-items: center; gap: 5px; font-size: 0.9rem;}

    .app-wrapper { background: #000; min-height: 100vh; color: white; font-family: sans-serif; }
    .content-body { padding: 20px; }
    .stats-grid { display: grid; grid-template-columns: 1fr; gap: 15px; margin-bottom: 30px; }
    .stat-card { background: #1a1a1a; padding: 20px; border-radius: 15px; border-left: 4px solid #FFD700; }
    .stat-card.main { background: #FFD700; color: #000; border: none; }
    
    .progress-section { background: #1a1a1a; padding: 20px; border-radius: 20px; }
    .progress-item { margin-bottom: 20px; }
    .progress-label { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.8rem; }
    .progress-bar-container { background: #333; height: 8px; border-radius: 4px; overflow: hidden; }
    .progress-bar { height: 100%; transition: width 0.5s ease-in-out; }
    
    /* Cores Dinâmicas */
    .progress-bar.yellow, .dot.yellow { background: #FFD700; }
    .progress-bar.green, .dot.green { background: #28a745; }
    .progress-bar.blue, .dot.blue { background: #007bff; }
    .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 5px; } 

    /* Força a exibição das barras mesmo que o valor seja baixo */
    .progress-bar-container { 
    background: #333 !important; 
    height: 12px !important; 
    margin-top: 5px;
    border-radius: 6px;
    }

   /* Cores das barras de progresso */
  .progress-bar.yellow { background-color: #FFD700 !important; }
  .progress-bar.blue { background-color: #007bff !important; }
  .progress-bar.green { background-color: #28a745 !important; }
  .progress-bar.red { background-color: #dc3545 !important; }

  /* Cores das bolinhas (dots) */
  .dot.yellow { background-color: #FFD700; }
  .dot.blue { background-color: #007bff; }
  .dot.green { background-color: #28a745; }
  .dot.red { background-color: #dc3545; }

    .bottom-nav {
        position: fixed;
        bottom: 15px; left: 15px; right: 15px;
        background-color: #333;
        height: 70px;
        border-radius: 20px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        z-index: 40;
    }
    .nav-item { display: flex; flex-direction: column; align-items: center; color: #999; font-size: 0.65rem; cursor: pointer; gap: 5px;}
    .nav-item.active {
        background-color: #FFFDE7;
        color: #000;
        padding: 10px 15px;
        border-radius: 15px;
        font-weight: bold;
    }


</style>

@code {
    private DashboardData stats = new();

    protected override void OnInitialized()
    {
        stats = GaragemService.GetDashboardStats();
    }

    private int CalcularPorcentagem(int qtd)
    {
        if (stats.QuantidadeOS == 0) return 0;
        return (qtd * 100) / stats.QuantidadeOS;
    }

    private void NavTo(string path) => Navigation.NavigateTo(path);
}